{
  "statusLine": {
    "type": "command",
    "command": "wt list statusline --format=claude-code"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "worktrunk@worktrunk": true,
    "ponytail@ponytail": true,
    "educational-style@private-agent-plugins": true,
    "mercury-coding-standards@private-agent-plugins": true,
    "mercury-pr-rescue@private-agent-plugins": true,
    "talaria-naming-conventions@private-agent-plugins": true,
    "mercury-cleanup-pass@private-agent-plugins": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "private-agent-plugins": {
      "source": {
        "source": "git",
        "url": "git@github.com:mercuryanalytics/private-agent-plugins.git"
      },
      "autoUpdate": true
    }
  },
  "awaySummaryEnabled": false,
  "autoUpdatesChannel": "stable",
  "autoDreamEnabled": true
}
